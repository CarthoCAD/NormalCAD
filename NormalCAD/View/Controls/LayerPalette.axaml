<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NormalCAD.View.Controls"
             x:Class="NormalCAD.View.Controls.LayerPalette">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="5" Margin="0,0,0,10">
      <TextBox Name="TxtNewLayerName" PlaceholderText="Nova Camada..." Width="150" Height="28" Background="{DynamicResource Theme.TextBoxBg}" Foreground="{DynamicResource Theme.Text}" BorderThickness="0" VerticalContentAlignment="Center"/>
      <Button Name="BtnAddLayer" Content="+" Width="28" Height="28" Background="#007ACC" Foreground="White" CornerRadius="4" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
    </StackPanel>
    <ListBox Name="LstLayers" Background="{DynamicResource Theme.PanelBg}" Foreground="{DynamicResource Theme.Text}" BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="local:LayerItem">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
            <Rectangle Grid.Column="1" Width="12" Height="12" Fill="{Binding ColorBrush}" RadiusX="2" RadiusY="2" Margin="5,0"/>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
